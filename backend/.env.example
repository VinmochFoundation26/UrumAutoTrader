# ── AutoTrader Bot — Environment Template ────────────────────────────────────
# Copy to .env and fill in every value.
# NEVER commit .env to git (it's in .gitignore).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
CORS_ORIGIN=https://yourdomain.com   # exact domain — no wildcard in production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379         # docker-compose service; use redis://localhost:6379 for local dev

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                       # debug | info | warn | error

# ── Chain / RPC ───────────────────────────────────────────────────────────────
RPC_URL=https://arb1.arbitrum.io/rpc
FALLBACK_RPC_URL=https://rpc.ankr.com/arbitrum   # auto-retry on primary failure
CHAIN_ID=42161
VAULT_ADDRESS=0x...                  # your deployed vault contract
STABLE_TOKEN=0x...                   # USDC contract on Arbitrum

# ── Keys — ROTATE BEFORE BETA LAUNCH ─────────────────────────────────────────
# Never share these. Never commit them.
BOT_PRIVATE_KEY=0x...                # wallet that signs all on-chain trades
ADMIN_KEY=                           # legacy CLI key (optional, leave blank)

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(48).toString('hex')|console.log"
JWT_SECRET=REPLACE_WITH_96_CHAR_RANDOM_HEX

# Generate hash: cd backend && node scripts/hash-password.js YourPassword
LOGIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# ── User / Trading ────────────────────────────────────────────────────────────
TEST_USER_ADDRESS=0x...              # wallet address for the trader
STABLE_DECIMALS=6
SYMBOLS=BTCUSDT,ETHUSDT,TAOUSDT,RENDERUSDT
MAX_CONCURRENT_TRADES=1

# ── Strategy ─────────────────────────────────────────────────────────────────
STRATEGY_MODE=trend_range_fork
STOCH_OS=35
STOCH_OB=80
STOCH_MID=50
STOCH_D_LEN=3

# ── Risk / Circuit Breaker ────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.05              # 5% for beta (conservative); raise to 0.10 after validation

# ── Fee Management ────────────────────────────────────────────────────────────
FEE_WALLET_ADDRESS=0x...              # platform fee recipient wallet (leave blank to skip fee transfers)

# ── Optional ─────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com
PRIVATE_RPC_URL=                     # MEV protection (Flashbots Arbitrum endpoint)

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Google Account → Security → App Passwords → Generate a 16-char app password
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char Google App Password (spaces ok)
ADMIN_EMAIL=admin@urumtrader.com         # receives new-user signup alerts + admin login
APP_URL=https://urumtrader.com           # used in email verification links
